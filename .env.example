# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://zrkktupibgnebhdxofpg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare R2
# ─────────────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=scraper
NEXT_PUBLIC_R2_PUBLIC_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Apify — atores compartilhados (tokens ficam no painel /admin/settings)
# ─────────────────────────────────────────────────────────────────────────────
APIFY_TIKTOK_ACTOR_IDS=clockworks/tiktok-hashtag-scraper,clockworks/tiktok-scraper
APIFY_YOUTUBE_ACTOR_IDS=streamers/youtube-shorts-scraper,easyapi/youtube-shorts-downloader

# ─────────────────────────────────────────────────────────────────────────────
# Zernio — chave global (IDs de conta por nicho ficam no painel /admin/settings)
# ─────────────────────────────────────────────────────────────────────────────
ZERNIO_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Groq — geração de legendas e classificação de notícias (Llama 3.3 70B)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Segurança — valida chamadas internas do scrapper-cron para a API
# ─────────────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Infra interna (não alterar em produção Docker Swarm)
# ─────────────────────────────────────────────────────────────────────────────
FFMPEG_WORKER_URL=http://scrapper-worker:3001
YTDLP_PATH=/usr/local/bin/yt-dlp

# ─────────────────────────────────────────────────────────────────────────────
# Deploy
# ─────────────────────────────────────────────────────────────────────────────
SCRAPPER_DOMAIN=bt.moiseskalebbe.cloud
SCRAPPER_IMAGE=ghcr.io/moi-kalebbe/scrapper:latest
SCRAPPER_WORKER_IMAGE=ghcr.io/moi-kalebbe/scrapper-worker:latest
SCRAPPER_CRON_IMAGE=ghcr.io/moi-kalebbe/scrapper-cron:latest
